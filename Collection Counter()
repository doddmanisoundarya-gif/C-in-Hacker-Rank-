from collections import Counter

# Number of shoes
X = int(input())

# Shoe sizes available
shoe_sizes = list(map(int, input().split()))
stock = Counter(shoe_sizes)

# Number of customers
N = int(input())

money = 0

for _ in range(N):
    size, price = map(int, input().split())

    if stock[size] > 0:
        money += price
        stock[size] -= 1

print(money)

