
#include <stdio.h>
#include<stdlib.h>
void update(int *a, int *b){
    if(*a>*b){
        *b=*a-*b;
        *a=(*a-*b)+*a;
    }
    else{
        *b=*b-*a;
        *a=(*a+*b)+*a;
    }
}

int main()
{
    int a, b;
    int *pa=&a, *pb=&b;
    scanf("%d %d", &a, &b);
    update(pa, pb);
    printf("%d\n%d", a,b);
    
    return 0;
}

